{
  "name": "@pingshian/agents-terminal-dashboard",
  "version": "0.1.4",
  "type": "module",
  "description": "Dashboard for OpenClaw agents — memory, agents, cron jobs, skills",
  "bin": {
    "agents-dashboard": "./bin/cli.js"
  },
  "files": [
    "dist/",
    "dist-server/",
    "bin/"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.server.json",
    "build:all": "npm run build",
    "preview": "vite preview",
    "server": "node dist-server/server/standalone.js",
    "start": "node bin/cli.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "agents",
    "dashboard",
    "memory",
    "cron"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pingshian0131/agents-dashboard-public"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.15.0",
    "openai": "^4.80.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0"
  }
}
